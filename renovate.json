{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":rebaseStalePrs",
    ":prHourlyLimitNone"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchPackageNames": ["*"],
      "automerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["ci-cd"]
    }
  ],
  "rangeStrategy": "pin"
}
